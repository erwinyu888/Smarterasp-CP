# Local secrets/config for Smarterasp-CP.
# Copy this file to .env and fill in real values. .env is ignored by git.

# ASP.NET
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5056

# Main database used by the rebuilt account panel and hosting control panel.
EHB_CONFIG_CONNECTION_STRING=

# Real Classic ASP checkout/payment host. Local /checkout/* paths redirect here.
LEGACY_CHECKOUT_BASE_URL=https://member3.smarterasp.net

# OpenSRS registrar API.
OPENSRS_API_URL=
OPENSRS_USERNAME=
OPENSRS_PRIVATE_KEY=

# Legacy hosting server agent.
# Builds calls such as http://{serverId}.{LEGACY_SERVER_DOMAIN_NAME}:{LEGACY_AGENT_PORT}/iis_api.asp
LEGACY_SERVER_DOMAIN_NAME=site4now.net
LEGACY_AGENT_SCHEME=http
LEGACY_AGENT_PORT=830
LEGACY_REMOTE_CMD_SCHEME=https
LEGACY_REMOTE_CMD_PORT=8443
LEGACY_REMOTE_CMD_PATH=/remotefunc.asp
LEGACY_REMOTE_CMD_TOKEN_HOST=win5000a.smarterasp.net
LEGACY_REMOTE_CMD_STATIC_TOKEN=
LEGACY_REMOTE_CMD_MD5_SEED=

# File Manager JSON listing agent.
# Upload legacy-agents/getFilesFolder.asp to http://winxxxx.site4now.net:830/new/getFilesFolder.asp.
# Current production mode supports encrypted unsigned requests and relies on the ASP path guard:
# h:\root\home\<cpLogin>\... only, with traversal/reparse checks.
# Set FM_AGENT_REQUIRE_SIGNATURE=1 on the ASP server and FM_AGENT_SHARED_SECRET here if signed mode is re-enabled.
FILE_MANAGER_AGENT_PATH=/new/getFilesFolder.asp
FILE_MANAGER_ACTION_AGENT_PATH=/new/fileManagerAction.asp
FM_AGENT_SHARED_SECRET=
# Set the same FILE_MANAGER_ENCRYPT_KEY value in ASP.NET and the LOCAL_ENCRYPT_KEY fallback
# in /new/getFilesFolder.asp and /new/fileManagerAction.asp.
# If blank, file-manager agents accept plain values for local/dev testing.
FILE_MANAGER_ENCRYPT_KEY=
FM_AGENT_ALLOW_SIGNED_PLAIN=0
FM_AGENT_REQUIRE_SIGNATURE=0

# Legacy public host/domain defaults used for generated database, mail, FTP, and control-panel URLs.
LEGACY_PUBLIC_DOMAIN=site4now.net

# Hosting defaults used when the legacy DB does not have an override.
HOSTING_DEFAULT_SHARED_IP=208.98.35.146
HOSTING_DEFAULT_DNS_SERVERS=NS1.SITE4NOW.NET,NS2.SITE4NOW.NET,NS3.SITE4NOW.NET
HOSTING_TEMP_DOMAIN_PATTERNS=tempurl|-site|.site4now.net

# Legacy SmarterMail gateway.
# Classic ASP calls this mail_api.
LEGACY_MAIL_API_BASE_URL=http://member.smarterasp.net/mailboxquota2
LEGACY_MAIL_DEFAULT_SERVER=

# Legacy OMS SOAP gateway.
# Classic ASP includes/configs_individual.inc sets omsWebServiceUrl to this value.
LEGACY_OMS_BASE_URL=http://member.smarterasp.net/WebServices/omsAdmin/

# Legacy shared API gateway.
# Classic ASP helper functions call api.smarterasp.net for Cloudflare, free SSL, recycle pool, firewall, etc.
LEGACY_SHARED_API_HOST=api.smarterasp.net
LEGACY_SHARED_API_SCHEME=http
LEGACY_SHARED_API_PORT=80

# App crypto.
# CONTROL_PANEL_CRYPTO_KEY is for new rebuilt-only data encrypted by CryptoHelper.Encrypt/Decrypt.
# PBKDF2_COMPATIBILITY_SALT is only for compatibility experiments, not proven Persits-compatible yet.
CONTROL_PANEL_CRYPTO_KEY=
PBKDF2_COMPATIBILITY_SALT=

# Account email-change verification.
EMAIL_VERIFY_SALT=

# Account-panel SMTP. Authentication is not required for these relays.
SMTP_PRIMARY_HOST=mail.smarterasp.net
SMTP_PRIMARY_PORT=8889
SMTP_FALLBACK_HOST=gw5000
SMTP_FALLBACK_PORT=8889
SMTP_FROM_EMAIL=noreply@smarterasp.net
SMTP_FROM_NAME=SmarterASP.NET
SMTP_TIMEOUT_MS=12000
SMTP_ADMIN_ALERT_RECIPIENTS=erwinyu888@gmail.com,307329698@qq.com
PUBLIC_APP_BASE_URL=http://localhost:5056

# Cloudflare Turnstile bot check on login.
# Site key is public and is served to the login page; secret key stays server-side.
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Legacy Persits wrapper keys.
# Keep these out of source control. Use only after compatibility is validated.
LEGACY_IMPORTKEY8=
LEGACY_FTP_PWD_KEY=
LEGACY_DB_PWD_KEY=
LEGACY_SERVER_PWD_KEY=
LEGACY_CP_PWD_KEY=

# Windows hosting home root used by file manager path validation
HOSTING_HOME_ROOT=h:\root\home
